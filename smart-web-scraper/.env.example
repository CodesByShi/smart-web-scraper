# Base URL of the site being scraped. books.toscrape.com is a sandbox
# site built specifically for scraping practice, so it's used as the
# default target here.
BASE_URL=https://books.toscrape.com

# Network behaviour
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2
REQUEST_DELAY_SECONDS=1

# Logging
LOG_LEVEL=INFO
